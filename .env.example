# ─── Base de datos ──────────────────────────────────────────────────────────
# Local (Docker)
DATABASE_URL="postgresql://apl_user:apl_pass@localhost:5432/apl_calculadora?schema=public"

# Producción (Neon Postgres) — copiar el connection string desde Neon dashboard
# DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxxx-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── Auth (NextAuth v5) ─────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-en-produccion-genera-uno-con-openssl-rand-base64-32"

# URL pública de la app (Vercel la setea automáticamente como NEXTAUTH_URL=VERCEL_URL)
# AUTH_URL="https://apl-calculadora-estimacion.vercel.app"

# ─── API pública ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
# En Vercel: NEXT_PUBLIC_API_URL="https://apl-calculadora-estimacion.vercel.app/api"

# ─── Docker (desarrollo local) ──────────────────────────────────────────────
POSTGRES_USER=apl_user
POSTGRES_PASSWORD=apl_pass
POSTGRES_DB=apl_calculadora
POSTGRES_PORT=5432
