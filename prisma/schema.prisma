generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH / USUARIOS ─────────────────────────────────────────────────────────

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   String    @unique @db.VarChar(50)  // SUPERUSUARIO | PRODUCT_OWNER | DESARROLLADOR | QA
  usuarios Usuario[]

  @@map("roles")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(200)
  email        String   @unique @db.VarChar(200)
  passwordHash String   @map("password_hash") @db.VarChar(200)
  activo       Boolean  @default(true)
  rolId        Int      @map("rol_id")
  rol          Rol      @relation(fields: [rolId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  proyectosEstimados ProyectoEstimador[]
  actividadesCreadas Actividad[]

  @@map("usuarios")
}

// ─── CATÁLOGOS ────────────────────────────────────────────────────────────────

model Lenguaje {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  componentes Componente[]

  @@map("lenguajes")
}

model Tecnologia {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  componentes Componente[]

  @@map("tecnologias")
}

model Grupo {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  componentes Componente[]

  @@map("grupos")
}

model TipoComponente {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  componentes Componente[]

  @@map("tipos_componente")
}

// ─── COMPONENTE ───────────────────────────────────────────────────────────────

model Componente {
  id               Int      @id @default(autoincrement())
  // id original del CSV — NO es PK, puede repetirse con distintos nombres
  idCsv            Int      @map("id_csv")
  nombreComponente String   @db.VarChar(200) @map("nombre_componente")
  publicar         Boolean  @default(true)
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  grupoId      Int            @map("grupo_id")
  tipoId       Int            @map("tipo_id")
  lenguajeId   Int            @map("lenguaje_id")
  tecnologiaId Int            @map("tecnologia_id")

  grupo      Grupo          @relation(fields: [grupoId],      references: [id])
  tipo       TipoComponente @relation(fields: [tipoId],       references: [id])
  lenguaje   Lenguaje       @relation(fields: [lenguajeId],   references: [id])
  tecnologia Tecnologia     @relation(fields: [tecnologiaId], references: [id])

  variables           VariableComponente[]
  itemsEstimacion     EstimacionItem[]
  actividadComponentes ActividadComponente[]

  @@unique([idCsv, nombreComponente, lenguajeId, tecnologiaId], name: "uq_componente_clave")
  @@index([grupoId])
  @@index([tipoId])
  @@index([lenguajeId])
  @@index([tecnologiaId])
  @@map("componentes")
}

// Una fila del CSV = un Componente + N VariableComponente (una por "Nombre Variables")
model VariableComponente {
  id              Int      @id @default(autoincrement())
  nombreVariable  String   @db.VarChar(200) @map("nombre_variable")
  tiempoBaseMin   Int      @map("tiempo_base_min")        // minutos enteros
  pctCopilot      Int      @default(0) @map("pct_copilot") // 0-100
  tiempoCopilotMin Int     @map("tiempo_copilot_min")
  pctTme          Int      @default(0) @map("pct_tme")     // 0-100
  tiempoTmeMin    Int      @map("tiempo_tme_min")
  rawOriginal     String?  @db.Text @map("raw_original")  // fila CSV original (trazabilidad)
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  componenteId Int        @map("componente_id")
  componente   Componente @relation(fields: [componenteId], references: [id], onDelete: Cascade)

  @@index([componenteId])
  @@map("variables_componente")
}

// ─── PROYECTO DE ESTIMACIÓN (con actividades) ─────────────────────────────────

model Proyecto {
  id              Int      @id @default(autoincrement())
  requerimiento   String   @db.VarChar(100)
  nombreProyecto  String   @db.VarChar(200) @map("nombre_proyecto")
  objetivo        String?  @db.Text
  fechaEstimacion DateTime? @map("fecha_estimacion") @db.Date
  fechaEjecucion  DateTime? @map("fecha_ejecucion")  @db.Date
  estimadoPor     String?  @db.VarChar(200) @map("estimado_por")
  supervisadoPor  String?  @db.VarChar(200) @map("supervisado_por")
  // Totales calculados al guardar
  totalBaseMin    Int      @default(0) @map("total_base_min")
  totalCopilotMin Int      @default(0) @map("total_copilot_min")
  totalTmeMin     Int      @default(0) @map("total_tme_min")
  estado          String   @default("ABIERTO")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  actividades  Actividad[]
  estimadores  ProyectoEstimador[]
  documentos   DocumentoEstimacion[]

  @@map("proyectos")
}

model Actividad {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(500)
  proceso     String?  @db.VarChar(100)
  bloque      String?  @db.VarChar(100)
  jornadas    Decimal? @db.Decimal(8, 2)
  fechaInicio DateTime? @map("fecha_inicio") @db.Date
  fechaFin    DateTime? @map("fecha_fin")    @db.Date
  orden       Int      @default(0)
  // Totales calculados
  totalBaseMin    Int @default(0) @map("total_base_min")
  totalCopilotMin Int @default(0) @map("total_copilot_min")
  totalTmeMin     Int @default(0) @map("total_tme_min")
  creadoPorId Int?     @map("creado_por_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  proyectoId  Int       @map("proyecto_id")
  proyecto    Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  creadoPor   Usuario?  @relation(fields: [creadoPorId], references: [id], onDelete: SetNull)

  componentes ActividadComponente[]

  @@index([proyectoId])
  @@map("actividades")
}

model ActividadComponente {
  id               Int      @id @default(autoincrement())
  cantidad         Int      @default(1)
  reutilizar       Boolean  @default(false)
  tiempoBaseMin    Int      @default(0) @map("tiempo_base_min")
  tiempoCopilotMin Int      @default(0) @map("tiempo_copilot_min")
  tiempoTmeMin     Int      @default(0) @map("tiempo_tme_min")
  createdAt        DateTime @default(now()) @map("created_at")

  actividadId  Int        @map("actividad_id")
  componenteId Int        @map("componente_id")

  actividad  Actividad  @relation(fields: [actividadId],  references: [id], onDelete: Cascade)
  componente Componente @relation(fields: [componenteId], references: [id])

  @@index([actividadId])
  @@index([componenteId])
  @@map("actividad_componentes")
}

// ─── ESTIMACIÓN ───────────────────────────────────────────────────────────────

model Estimacion {
  id              Int      @id @default(autoincrement())
  nombre          String?  @db.VarChar(200)
  descripcion     String?  @db.Text
  totalBaseMin    Int      @default(0) @map("total_base_min")
  totalCopilotMin Int      @default(0) @map("total_copilot_min")
  totalTmeMin     Int      @default(0) @map("total_tme_min")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  items EstimacionItem[]

  @@map("estimaciones")
}

// Pivot: qué componentes y en qué cantidad forman esta estimación
model EstimacionItem {
  id               Int      @id @default(autoincrement())
  cantidad         Int      @default(1)
  tiempoBaseMin    Int      @map("tiempo_base_min")
  tiempoCopilotMin Int      @map("tiempo_copilot_min")
  tiempoTmeMin     Int      @map("tiempo_tme_min")
  createdAt        DateTime @default(now()) @map("created_at")

  estimacionId Int        @map("estimacion_id")
  componenteId Int        @map("componente_id")

  estimacion Estimacion @relation(fields: [estimacionId], references: [id], onDelete: Cascade)
  componente Componente @relation(fields: [componenteId], references: [id])

  @@index([estimacionId])
  @@index([componenteId])
  @@map("estimacion_items")
}

// ─── PROYECTO ESTIMADORES (pivot) ─────────────────────────────────────────────

model ProyectoEstimador {
  proyectoId Int      @map("proyecto_id")
  usuarioId  Int      @map("usuario_id")
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([proyectoId, usuarioId])
  @@map("proyecto_estimadores")
}

// ─── DOCUMENTO DE ESTIMACIÓN (MAU / adjunto) ──────────────────────────────────

model DocumentoEstimacion {
  id           Int      @id @default(autoincrement())
  proyectoId   Int      @map("proyecto_id")
  nombre       String   @db.VarChar(300)
  tipo         String   @db.VarChar(20)           // pdf | docx | txt
  contenidoRaw String   @db.Text                  @map("contenido_raw")
  totalChunks  Int      @default(0)               @map("total_chunks")
  estado       String   @default("PROCESANDO")    // PROCESANDO | LISTO | ERROR
  createdAt    DateTime @default(now())            @map("created_at")
  updatedAt    DateTime @updatedAt                 @map("updated_at")

  proyecto Proyecto        @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  chunks   DocumentoChunk[]

  @@index([proyectoId])
  @@map("documentos_estimacion")
}

// Chunks de texto + embedding (columna embedding vector(768) agregada vía SQL raw)
model DocumentoChunk {
  id          Int      @id @default(autoincrement())
  documentoId Int      @map("documento_id")
  proyectoId  Int      @map("proyecto_id")
  seccion     String?  @db.VarChar(500)
  contenido   String   @db.Text
  orden       Int
  createdAt   DateTime @default(now()) @map("created_at")

  documento DocumentoEstimacion @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@index([documentoId])
  @@map("documento_chunks")
}
